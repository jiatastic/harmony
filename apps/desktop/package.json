{
  "name": "@harmony/desktop",
  "version": "0.0.24",
  "private": true,
  "description": "Harmony desktop app for managing worktrees, terminals, and AI coding agents.",
  "main": "./out/main/index.js",
  "author": "Haoxiang Jia",
  "homepage": "https://jiatastic.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiatastic/harmony.git"
  },
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac --config.directories.output=/var/tmp/harmony-desktop-dist",
    "build:mac:unsigned": "npm run build && electron-builder --mac --config.mac.identity=null --config.mac.hardenedRuntime=false --config.directories.output=/var/tmp/harmony-desktop-dist",
    "release:mac": "npm run build && electron-builder --mac --publish always --config.directories.output=/var/tmp/harmony-desktop-dist",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "react-grab": "^0.1.28"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
